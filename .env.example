# Copy to .env (or set in Railway dashboard) for production overrides.

# Port to bind. Railway provides PORT automatically; only set locally for prod testing.
# PORT=3001

# Comma-separated CORS allowlist for production. Leave empty in dev.
# Example: ALLOWED_ORIGIN=https://oryxlab.app,https://oryxlab-production.up.railway.app
# ALLOWED_ORIGIN=

# Explicit prod toggle (auto-detected from dist/ folder if not set).
# NODE_ENV=production
