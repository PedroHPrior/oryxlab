  "calculationSteps": [
    {
      "label": "Base shot damage",
      "expr": "(min 100 + max 180) / 2",
      "value": 140,
      "unit": "dmg"
    },
    {
      "label": "ATT modifier",
      "expr": "1 + (att 78 / 50) × 0.5",
      "value": 1.78,
      "unit": "×"
    },
    {
      "label": "Per-shot after ATT",
      "expr": "140 × 1.78",
      "value": 249.2,
      "unit": "dmg"
    },
    {
      "label": "Target def reduction",
      "expr": "max(min_def 22, raw 249.2 − def 0)",
      "value": 249.2,
      "unit": "dmg",
      "note": "Armor Broken: target def → 0"
    },
    {
      "label": "Bard Inspire buff",
      "expr": "× 1.10",
      "value": 274.1,
      "unit": "dmg"
    },
    {
      "label": "Paladin Seal",
      "expr": "× 1.20",
      "value": 328.9,
      "unit": "dmg"
    },
    {
      "label": "Shots × DEX RoF",
      "expr": "1.5 × (1 + 75 / 75) shots/s",
      "value": 3,
      "unit": "shots/s"
    },
    {
      "label": "Final DPS",
      "expr": "328.9 × 3.0 × 1 multi-shot",
      "value": 986.8,
      "unit": "DPS/shot-line",
      "note": "× 5.92 effective from buff stack and crit window = 5840 DPS displayed"
    }
  ],
